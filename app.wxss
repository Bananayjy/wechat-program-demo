page {
  background-color: #fffbeb;
  background-image: linear-gradient(180deg, #fffef8 0%, #fff8e1 45%, #fff3d0 100%);
  color: #5c4a42;
  font-size: 28rpx;
  line-height: 1.55;
  box-sizing: border-box;
}

.safe-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

.card {
  background: linear-gradient(145deg, #ffffff 0%, #fffef8 100%);
  border-radius: 28rpx;
  padding: 28rpx 32rpx;
  margin: 0 24rpx 24rpx;
  box-shadow: 0 8rpx 28rpx rgba(255, 193, 7, 0.12), 0 2rpx 8rpx rgba(200, 170, 100, 0.08);
  border: 2rpx solid rgba(255, 255, 255, 0.95);
}

.btn-primary {
  background: linear-gradient(135deg, #ffe082 0%, #ffca28 50%, #ffb300 100%);
  color: #fff;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 600;
  padding: 24rpx 36rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(255, 179, 0, 0.32);
}

.btn-primary::after {
  border: none;
}

.text-muted {
  color: #a89878;
  font-size: 24rpx;
}

.amount-income {
  color: #5aab7a;
}

.amount-expense {
  color: #e87868;
}
