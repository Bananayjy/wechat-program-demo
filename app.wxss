page {
  background-color: #f5f6f8;
  color: #1a1a1a;
  font-size: 28rpx;
  line-height: 1.5;
  box-sizing: border-box;
}

.safe-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin: 0 24rpx 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.btn-primary {
  background: #1a7f5a;
  color: #fff;
  border-radius: 12rpx;
  font-size: 30rpx;
  padding: 22rpx 32rpx;
  border: none;
}

.btn-primary::after {
  border: none;
}

.text-muted {
  color: #8a8a8a;
  font-size: 24rpx;
}

.amount-income {
  color: #1a7f5a;
}

.amount-expense {
  color: #c45c3e;
}
