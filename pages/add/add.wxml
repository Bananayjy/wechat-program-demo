<view class="page safe-bottom">
  <view class="card">
    <view class="seg">
      <view
        class="seg-item {{txType === 'expense' ? 'on' : ''}}"
        data-type="expense"
        bindtap="onTypeTap"
      >支出</view>
      <view
        class="seg-item {{txType === 'income' ? 'on' : ''}}"
        data-type="income"
        bindtap="onTypeTap"
      >收入</view>
    </view>

    <view class="field">
      <text class="label">金额（元）</text>
      <view class="amount-row">
        <view class="input amount amount-display-wrap">
          <text class="amount-display {{amountYuan ? '' : 'amount-placeholder'}}">￥{{amountYuan || '0.00'}}</text>
        </view>
      </view>
    </view>

    <view class="field">
      <text class="label">分类</text>
      <scroll-view scroll-x class="cat-scroll" enable-flex>
        <view
          wx:for="{{filteredCategories}}"
          wx:key="id"
          class="chip {{categoryId === item.id ? 'on' : ''}}"
          data-id="{{item.id}}"
          bindtap="onCategoryTap"
        >
          <image class="chip-icon" src="{{item.iconSrc}}" mode="aspectFit" />
          <text>{{item.name}}</text>
        </view>
      </scroll-view>
    </view>

    <view class="field">
      <text class="label">日期</text>
      <picker mode="date" value="{{dateStr}}" bindchange="onDateChange">
        <view class="picker-val">{{dateStr}}</view>
      </picker>
    </view>

    <view class="field">
      <text class="label">备注</text>
      <input
        class="input"
        placeholder="可选"
        value="{{note}}"
        maxlength="80"
        bindinput="onNoteInput"
      />
    </view>

      <view class="calc">
        <view class="calc-row">
          <view class="calc-key" data-key="7" bindtap="onCalcKey">7</view>
          <view class="calc-key" data-key="8" bindtap="onCalcKey">8</view>
          <view class="calc-key" data-key="9" bindtap="onCalcKey">9</view>
          <view class="calc-key-spacer"></view>
        </view>
        <view class="calc-row">
          <view class="calc-key" data-key="4" bindtap="onCalcKey">4</view>
          <view class="calc-key" data-key="5" bindtap="onCalcKey">5</view>
          <view class="calc-key" data-key="6" bindtap="onCalcKey">6</view>
          <view class="calc-key-spacer"></view>
        </view>
        <view class="calc-row">
          <view class="calc-key" data-key="1" bindtap="onCalcKey">1</view>
          <view class="calc-key" data-key="2" bindtap="onCalcKey">2</view>
          <view class="calc-key" data-key="3" bindtap="onCalcKey">3</view>
          <view class="calc-key-spacer"></view>
        </view>
        <view class="calc-row">
          <view class="calc-key calc-key-soft" data-key="clear" bindtap="onCalcKey">C</view>
          <view class="calc-key" data-key="0" bindtap="onCalcKey">0</view>
          <view class="calc-key" data-key="." bindtap="onCalcKey">.</view>
          <view class="calc-key calc-key-del" data-key="del" bindtap="onCalcKey">⌫</view>
        </view>
      </view>
  </view>

  

  <button class="btn-primary save" bindtap="onSave">保存</button>
</view>
