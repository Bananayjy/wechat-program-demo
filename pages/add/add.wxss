.page {
  padding: 24rpx 0 48rpx;
  min-height: 100vh;
}

.seg {
  display: flex;
  background: #eef0f3;
  border-radius: 12rpx;
  padding: 6rpx;
  margin-bottom: 32rpx;
}

.seg-item {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  border-radius: 10rpx;
  font-size: 28rpx;
  color: #666;
}

.seg-item.on {
  background: #fff;
  color: #1a7f5a;
  font-weight: 600;
}

.field {
  margin-bottom: 28rpx;
}

.label {
  display: block;
  color: #8a8a8a;
  font-size: 24rpx;
  margin-bottom: 12rpx;
}

.input {
  background: #f3f4f6;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 30rpx;
}

.input.amount {
  font-size: 44rpx;
  font-weight: 600;
}

.cat-scroll {
  white-space: nowrap;
  display: flex;
  flex-direction: row;
  width: 100%;
}

.chip {
  display: inline-block;
  padding: 14rpx 28rpx;
  margin-right: 16rpx;
  background: #f3f4f6;
  border-radius: 999rpx;
  font-size: 26rpx;
}

.chip.on {
  background: #d8f0e6;
  color: #1a7f5a;
  font-weight: 600;
}

.picker-val {
  padding: 20rpx 24rpx;
  background: #f3f4f6;
  border-radius: 12rpx;
  font-size: 30rpx;
}

.save {
  margin: 0 24rpx;
  width: auto;
}
