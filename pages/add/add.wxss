.page {
  padding: 28rpx 0 48rpx;
  min-height: 100vh;
}

.seg {
  display: flex;
  background: rgba(255, 193, 7, 0.14);
  border-radius: 999rpx;
  padding: 8rpx;
  margin-bottom: 36rpx;
}

.seg-item {
  flex: 1;
  text-align: center;
  padding: 18rpx 16rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  color: #9a8a78;
  font-weight: 500;
}

.seg-item.on {
  background: linear-gradient(135deg, #fff 0%, #fffbeb 100%);
  color: #d48c00;
  font-weight: 700;
  box-shadow: 0 4rpx 16rpx rgba(255, 193, 7, 0.22);
}

.field {
  margin-bottom: 32rpx;
}

.label {
  display: block;
  color: #a89878;
  font-size: 24rpx;
  margin-bottom: 14rpx;
  font-weight: 600;
}

.input {
  background: rgba(255, 224, 130, 0.2);
  border-radius: 20rpx;
  padding: 22rpx 26rpx;
  font-size: 30rpx;
  border: 2rpx solid rgba(255, 193, 7, 0.18);
}

.input.amount {
  font-size: 46rpx;
  font-weight: 700;
  color: #5c4a42;
}

.cat-scroll {
  white-space: nowrap;
  display: flex;
  flex-direction: row;
  width: 100%;
}

.chip {
  display: inline-block;
  padding: 16rpx 32rpx;
  margin-right: 16rpx;
  background: rgba(255, 224, 130, 0.22);
  border-radius: 999rpx;
  font-size: 26rpx;
  color: #7a6a58;
  border: 2rpx solid transparent;
}

.chip.on {
  background: linear-gradient(135deg, #fff8e1 0%, #ffecb3 100%);
  color: #c77800;
  font-weight: 700;
  border-color: rgba(255, 160, 0, 0.38);
}

.picker-val {
  padding: 22rpx 26rpx;
  background: rgba(255, 224, 130, 0.2);
  border-radius: 20rpx;
  font-size: 30rpx;
  border: 2rpx solid rgba(255, 193, 7, 0.18);
}

.save {
  margin: 0 24rpx;
  width: auto;
}
