.page {
  padding: 28rpx 0 48rpx;
  min-height: 100vh;
}

.ledger-card-stats {
  padding: 0;
  margin-bottom: 12rpx;
}

.ledger-line-stats {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 22rpx 28rpx;
  font-size: 28rpx;
  color: #6b5a4a;
  letter-spacing: 0.6rpx;
}

.ledger-label-stats {
  font-weight: 700;
  color: #8b7a58;
}

.ledger-val-stats {
  color: #d48c00;
  font-weight: 600;
  max-width: 70%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.month-line {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 28rpx;
  margin-bottom: 28rpx;
  color: #6b5a4a;
  letter-spacing: 0.6rpx;
}

.month-val {
  color: #d48c00;
  font-weight: 700;
}

.sum-row {
  display: flex;
  justify-content: space-between;
  gap: 32rpx;
}

.sum-amt {
  font-size: 38rpx;
  font-weight: 700;
  margin-top: 10rpx;
  letter-spacing: 0.5rpx;
}

.block-title {
  font-weight: 700;
  margin-bottom: 24rpx;
  display: block;
  font-size: 28rpx;
  color: #8b7a58;
  letter-spacing: 1rpx;
}

.bar-row {
  display: flex;
  align-items: center;
  margin-bottom: 22rpx;
  gap: 14rpx;
}

.bar-name {
  width: 120rpx;
  font-size: 24rpx;
  flex-shrink: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #7a6a58;
}

.bar-track {
  flex: 1;
  height: 22rpx;
  background: rgba(255, 193, 7, 0.14);
  border-radius: 0;
  overflow: hidden;
  border: 2rpx solid rgba(154, 122, 52, 0.35);
}

.bar-fill {
  height: 100%;
  border-radius: 0;
  min-width: 6rpx;
}

.bar-fill.expense {
  background: linear-gradient(90deg, #ffd4a8 0%, #f29878 50%, #e87868 100%);
}

.bar-fill.income {
  background: linear-gradient(90deg, #d4f0c4 0%, #8fd4a8 50%, #5aab7a 100%);
}

.bar-amt {
  width: 100rpx;
  text-align: right;
  font-size: 22rpx;
  color: #8b7a58;
  flex-shrink: 0;
  font-weight: 700;
}
