<view class="page safe-bottom">
  <view class="card">
    <view class="seg small">
      <view
        class="seg-item {{currentType === 'expense' ? 'on' : ''}}"
        data-type="expense"
        bindtap="onTypeTap"
      >
        支出
      </view>
      <view
        class="seg-item {{currentType === 'income' ? 'on' : ''}}"
        data-type="income"
        bindtap="onTypeTap"
      >
        收入
      </view>
    </view>
    <view class="text-muted switch-hint">
      当前维护：{{currentType === 'expense' ? '支出' : '收入'}}分类
    </view>
  </view>

  <view class="card">
    <text class="section-title">{{currentType === 'expense' ? '支出' : '收入'}}分类（网格）</text>
    <view class="grid">
      <view wx:for="{{categoryList}}" wx:key="id" class="cat-card">
        <view class="cat-main">
          <image class="cat-icon" src="{{item.iconSrc}}" mode="aspectFit" />
          <text class="cat-name">{{item.name}}</text>
        </view>
        <view class="cat-ops">
          <text class="link" data-id="{{item.id}}" bindtap="onEditName">改名</text>
          <text class="link" data-id="{{item.id}}" bindtap="onEditIcon">换图标</text>
          <text class="link danger" data-id="{{item.id}}" bindtap="onRemove">删除</text>
        </view>
      </view>
      <view class="cat-card add-placeholder" wx:if="{{showAddPlaceholder}}"></view>
      <view class="cat-card add-card" bindtap="openCreateModal">
        <view class="add-icon-wrap">
          <text class="add-plus">+</text>
        </view>
        <text class="add-label">新增分类</text>
      </view>
    </view>
  </view>

  <view class="text-muted tip">有流水引用的分类不可删除</view>

  <view class="modal-mask" wx:if="{{showCreateModal}}" bindtap="closeCreateModal">
    <view class="modal-panel card" catchtap="noop">
      <text class="section-title">新增{{currentType === 'expense' ? '支出' : '收入'}}分类</text>
      <view class="add-row">
        <input
          class="input"
          placeholder="新分类名称"
          value="{{newName}}"
          maxlength="12"
          bindinput="onNewNameInput"
        />
      </view>
      <view class="icon-picker">
        <view
          wx:for="{{iconOptions}}"
          wx:key="key"
          class="icon-option {{newIconKey === item.key ? 'on' : ''}}"
          data-key="{{item.key}}"
          bindtap="onPickNewIcon"
        >
          <image src="{{item.src}}" mode="aspectFit" />
          <text>{{item.name}}</text>
        </view>
      </view>
      <view class="modal-actions">
        <button class="btn-ghost" bindtap="closeCreateModal">取消</button>
        <button class="btn-mini" bindtap="confirmCreate">确定</button>
      </view>
    </view>
  </view>

  <view class="modal-mask" wx:if="{{showEditIconModal}}" bindtap="closeEditIconModal">
    <view class="modal-panel card" catchtap="noop">
      <text class="section-title">修改图标</text>
      <view class="icon-picker">
        <view
          wx:for="{{iconOptions}}"
          wx:key="key"
          class="icon-option {{editIconKey === item.key ? 'on' : ''}}"
          data-key="{{item.key}}"
          bindtap="onPickEditIcon"
        >
          <image src="{{item.src}}" mode="aspectFit" />
          <text>{{item.name}}</text>
        </view>
      </view>
      <view class="modal-actions">
        <button class="btn-ghost" bindtap="closeEditIconModal">取消</button>
        <button class="btn-mini" bindtap="confirmEditIcon">确定</button>
      </view>
    </view>
  </view>
</view>
