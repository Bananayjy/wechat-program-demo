.page {
  padding: 24rpx 0 48rpx;
  min-height: 100vh;
}

.cell {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 30rpx;
  padding: 32rpx 28rpx;
}

.chev {
  color: #ccc;
  font-size: 36rpx;
}

.block-title {
  font-weight: 600;
  margin-bottom: 8rpx;
  display: block;
}

.sub {
  display: block;
  margin-bottom: 20rpx;
  font-size: 22rpx;
  line-height: 1.4;
}

.field {
  margin-bottom: 20rpx;
}

.label {
  font-size: 24rpx;
  color: #8a8a8a;
  margin-bottom: 8rpx;
  display: block;
}

.input {
  background: #f3f4f6;
  border-radius: 12rpx;
  padding: 18rpx 22rpx;
  font-size: 26rpx;
}

.switch-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  font-size: 28rpx;
}

.sync-btns {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.btn-outline {
  flex: 1;
  min-width: 160rpx;
  font-size: 26rpx;
  padding: 16rpx 12rpx;
  background: #fff;
  color: #1a7f5a;
  border: 1rpx solid #1a7f5a;
  border-radius: 12rpx;
  line-height: 1.4;
}

.btn-outline::after {
  border: none;
}

.footer {
  text-align: center;
  padding: 40rpx;
  font-size: 24rpx;
}
