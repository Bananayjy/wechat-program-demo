.page {
  padding: 28rpx 0 48rpx;
  min-height: 100vh;
}

.cell {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 30rpx;
  padding: 34rpx 28rpx;
  font-weight: 600;
  color: #5c4a42;
}

.cell-danger {
  color: #c45c50;
}

.cell-danger .chev {
  color: rgba(232, 120, 104, 0.65);
}

.clear-hint {
  display: block;
  margin: -8rpx 40rpx 20rpx;
  font-size: 22rpx;
  line-height: 1.45;
}

.chev {
  color: #e8dcc8;
  font-size: 40rpx;
  font-weight: 300;
}

.block-title {
  font-weight: 700;
  margin-bottom: 10rpx;
  display: block;
  color: #8b7a58;
}

.sub {
  display: block;
  margin-bottom: 22rpx;
  font-size: 22rpx;
  line-height: 1.45;
}

.field {
  margin-bottom: 22rpx;
}

.label {
  font-size: 24rpx;
  color: #a89878;
  margin-bottom: 10rpx;
  display: block;
}

.input {
  background: rgba(255, 224, 130, 0.22);
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
  font-size: 26rpx;
  border: 2rpx solid rgba(255, 193, 7, 0.2);
}

.switch-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 22rpx;
  font-size: 28rpx;
  color: #5c4a42;
}

.sync-btns {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.btn-outline {
  flex: 1;
  min-width: 160rpx;
  font-size: 26rpx;
  padding: 18rpx 12rpx;
  background: #fff;
  color: #d48c00;
  border: 2rpx solid rgba(255, 193, 7, 0.45);
  border-radius: 999rpx;
  line-height: 1.4;
  font-weight: 600;
}

.btn-outline::after {
  border: none;
}

.footer {
  text-align: center;
  padding: 48rpx;
  font-size: 24rpx;
  color: #c4b4a8;
}
