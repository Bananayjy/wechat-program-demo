<view class="page safe-bottom">
  <view class="profile-card">
    <view wx:if="{{isLoggedIn}}">
      <view class="profile-main">
        <button class="avatar-wrap" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
          <image
            wx:if="{{profileAvatar}}"
            class="avatar-img"
            src="{{profileAvatar}}"
            mode="aspectFill"
          />
          <view wx:else class="avatar-placeholder">头像</view>
        </button>
        <view class="profile-text">
          <text class="profile-name">{{profileNick || username || '未设置昵称'}}</text>
          <text class="profile-user muted" wx:if="{{username}}">@{{username}}</text>
        </view>
      </view>
      <view class="nick-row">
        <text class="label">微信昵称</text>
        <input
          class="input nick-input"
          type="nickname"
          placeholder="填写昵称"
          value="{{editNick}}"
          bindinput="onEditNick"
          bindblur="saveNickName"
        />
      </view>
      <view class="profile-actions">
        <button class="btn-tiny" size="mini" bindtap="bindWechat">同步微信绑定</button>
        <button class="btn-tiny btn-danger" size="mini" bindtap="logout">退出登录</button>
      </view>
    </view>
    <view wx:else>
      <text class="profile-name">游客模式</text>
      <text class="profile-user muted">可直接记账，数据仅保存在本机</text>
      <view class="profile-actions guest-actions">
        <button class="btn-tiny btn-login" size="mini" bindtap="goLogin">登录账号</button>
      </view>
    </view>
  </view>

  <view class="card cell" bindtap="goLedgerManage">
    <text>账本管理</text>
    <text class="chev">›</text>
  </view>

  <view class="card cell" bindtap="goCategories">
    <text>分类管理</text>
    <text class="chev">›</text>
  </view>

  <view class="card cell" bindtap="onExport">
    <text>导出 CSV</text>
    <text class="chev">›</text>
  </view>

  <view class="card cell cell-danger" bindtap="onClearLocal">
    <text>清除本地数据</text>
    <text class="chev">›</text>
  </view>
  <text class="text-muted clear-hint">将删除当前模式（游客或登录账号）在本机的流水与自定义分类，同步配置也会清空，且无法恢复</text>

  <view class="card">
    <text class="block-title">数据同步（可选）</text>
    <text class="text-muted sub">使用云开发云函数；业务路径以 / 开头，不含 /kapi</text>
    <view class="field">
      <text class="label">云环境 ID（可选）</text>
      <input
        class="input"
        placeholder="留空则使用当前云环境"
        value="{{cloudEnvId}}"
        bindinput="onCloudEnvInput"
      />
    </view>
    <view class="field">
      <text class="label">备用 https 站点根地址（可选）</text>
      <input
        class="input"
        placeholder="https://api.example.com"
        value="{{apiBase}}"
        bindinput="onApiBaseInput"
      />
    </view>
    <label class="switch-row">
      <text>启用同步</text>
      <switch checked="{{syncEnabled}}" bindchange="onSyncSwitch" />
    </label>
    <view class="sync-btns">
      <button class="btn-outline" bindtap="onSaveSync">保存配置</button>
      <button class="btn-outline" bindtap="onPush">上传</button>
      <button class="btn-outline" bindtap="onPull">拉取</button>
    </view>
  </view>

  <view class="footer text-muted">小账本 · 本地存储 · 安心守护</view>
</view>
