@import '../add/add.wxss';

.actions {
  display: flex;
  gap: 24rpx;
  margin: 0 24rpx;
  align-items: stretch;
}

.btn-del {
  flex: 1;
  background: #fff;
  color: #e87868;
  border: 2rpx solid rgba(232, 120, 104, 0.45);
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 600;
  padding: 22rpx 32rpx;
}

.btn-del::after {
  border: none;
}

.save {
  flex: 2;
  margin: 0;
}
