@import '../add/add.wxss';

.actions {
  display: flex;
  gap: 24rpx;
  margin: 0 24rpx;
  align-items: stretch;
}

.btn-del {
  flex: 1;
  background: #fff;
  color: #e87868;
  border: 3rpx solid rgba(196, 92, 80, 0.55);
  border-radius: 0;
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  padding: 22rpx 32rpx;
  box-shadow: 4rpx 0 0 rgba(196, 92, 80, 0.2), 0 4rpx 0 rgba(196, 92, 80, 0.2);
}

.btn-del::after {
  border: none;
}

.save {
  flex: 2;
  margin: 0;
}
