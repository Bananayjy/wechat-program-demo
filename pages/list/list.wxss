.page {
  padding: 28rpx 0 48rpx;
  min-height: 100vh;
}

.toolbar {
  margin-bottom: 12rpx;
}

.ledger-card {
  padding: 0;
  margin-bottom: 12rpx;
}

.ledger-line {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 22rpx 28rpx;
  font-size: 28rpx;
  color: #6b5a4a;
  letter-spacing: 0.6rpx;
}

.ledger-label {
  font-weight: 700;
  color: #8b7a58;
}

.ledger-val {
  color: #d48c00;
  font-weight: 600;
  max-width: 70%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.filter-card {
  padding: 8rpx 0;
}

.filter-seg-wrap {
  padding: 12rpx 24rpx 20rpx;
}

.filter-seg-label {
  display: block;
  font-size: 24rpx;
  color: #a89878;
  font-weight: 600;
  margin-bottom: 14rpx;
}

.filter-seg {
  display: flex;
  background: rgba(255, 193, 7, 0.14);
  border-radius: 0;
  padding: 6rpx;
  border: 3rpx solid rgba(91, 66, 21, 0.4);
}

.filter-seg-item {
  flex: 1;
  text-align: center;
  padding: 18rpx 12rpx;
  border-radius: 0;
  font-size: 28rpx;
  color: #9a8a78;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.filter-seg-item.on {
  background: linear-gradient(135deg, #fff 0%, #fffbeb 100%);
  color: #5b4215;
  font-weight: 700;
  border: 2rpx solid rgba(138, 102, 34, 0.45);
  box-shadow: 3rpx 0 0 rgba(138, 102, 34, 0.22), 0 3rpx 0 rgba(138, 102, 34, 0.22);
}

.filter-line {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 28rpx;
  color: #6b5a4a;
  padding: 10rpx 28rpx;
}

.filter-line-border {
  border-top: 0rpx solid rgba(255, 193, 7, 0.2);
  border-bottom: 0rpx solid rgba(255, 193, 7, 0.2);
}

.month-header {
  padding: 20rpx 28rpx 16rpx;
  margin-top: 8rpx;
  background: rgba(255, 224, 130, 0.18);
  border-radius: 0;
  border: 3rpx solid rgba(154, 122, 52, 0.35);
  box-shadow: 4rpx 0 0 rgba(154, 122, 52, 0.2), 0 4rpx 0 rgba(154, 122, 52, 0.2);
  margin-left: 24rpx;
  margin-right: 24rpx;
}

.month-header-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.month-title {
  flex: 1;
  font-size: 30rpx;
  font-weight: 700;
  color: #8b7a58;
  letter-spacing: 1rpx;
}

.month-chev {
  font-size: 24rpx;
  color: #a89878;
  margin-left: 16rpx;
}

.month-summary {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  margin-top: 12rpx;
  font-size: 24rpx;
  gap: 8rpx;
}

.month-sum-label {
  color: #a89878;
  margin-right: 4rpx;
}

.month-sum-sep {
  color: #c4b4a8;
  padding: 0 4rpx;
}

.day-title-row {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  align-items: baseline;
  gap: 12rpx;
  padding: 20rpx 36rpx 8rpx;
}

.day-date {
  font-size: 26rpx;
  color: #b8a080;
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

.day-summary {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  font-size: 22rpx;
  gap: 6rpx;
}

.day-sum-sep {
  color: #c4b4a8;
  padding: 0 2rpx;
}

.filter-val {
  color: #d48c00;
  font-weight: 600;
}

.empty {
  text-align: center;
  padding: 100rpx 32rpx;
  font-size: 28rpx;
  color: #b8a896;
}

.list-card {
  padding: 0;
  overflow: hidden;
}

.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 28rpx;
  border-bottom: 3rpx dashed rgba(154, 122, 52, 0.28);
}

.row:last-child {
  border-bottom: none;
}

.row-left {
  flex: 1;
  min-width: 0;
}

.cat-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #5c4a42;
  display: block;
  letter-spacing: 1rpx;
}

.note {
  font-size: 24rpx;
  margin-top: 8rpx;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.row-amt {
  font-size: 32rpx;
  font-weight: 700;
  margin-left: 16rpx;
}
