.page {
  padding: 28rpx 0 48rpx;
  min-height: 100vh;
}

.toolbar {
  margin-bottom: 12rpx;
}

.filter-line {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 28rpx;
  color: #6b5a4a;
}

.filter-val {
  color: #d48c00;
  font-weight: 600;
}

.empty {
  text-align: center;
  padding: 100rpx 32rpx;
  font-size: 28rpx;
  color: #b8a896;
}

.day-title {
  padding: 20rpx 36rpx 12rpx;
  font-size: 26rpx;
  color: #b8a080;
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

.list-card {
  padding: 0;
  overflow: hidden;
}

.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 28rpx;
  border-bottom: 2rpx dashed rgba(255, 193, 7, 0.2);
}

.row:last-child {
  border-bottom: none;
}

.row-left {
  flex: 1;
  min-width: 0;
}

.cat-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #5c4a42;
  display: block;
}

.note {
  font-size: 24rpx;
  margin-top: 8rpx;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.row-amt {
  font-size: 32rpx;
  font-weight: 700;
  margin-left: 16rpx;
}
