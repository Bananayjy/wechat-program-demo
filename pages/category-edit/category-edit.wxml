<view class="page safe-bottom">
  <view class="card">
    <text class="title">分类管理</text>
    <text class="desc text-muted">请选择要维护的分类类型</text>
    <view class="seg">
      <view
        class="seg-item {{activeType === 'expense' ? 'on' : ''}}"
        data-type="expense"
        bindtap="onTypeTap"
      >支出分类</view>
      <view
        class="seg-item {{activeType === 'income' ? 'on' : ''}}"
        data-type="income"
        bindtap="onTypeTap"
      >收入分类</view>
    </view>
    <view class="hint">进入后可网格维护：名称、图标、删除</view>
  </view>
</view>
