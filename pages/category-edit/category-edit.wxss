@import '../add/add.wxss';

.page {
  padding: 28rpx 0 48rpx;
  min-height: 100vh;
}

.add-bar {
  margin-bottom: 24rpx;
}

.seg.small {
  margin-bottom: 22rpx;
}

.add-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.add-row .input {
  flex: 1;
  background: rgba(255, 224, 130, 0.2);
  border-radius: 0;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  border: 3rpx solid rgba(138, 102, 34, 0.35);
  box-shadow: inset 0 0 0 2rpx rgba(255, 255, 255, 0.45);
}

.btn-mini {
  font-size: 26rpx;
  padding: 18rpx 32rpx;
  background: linear-gradient(135deg, #ffe082 0%, #ffca28 100%);
  color: #5b4215;
  border-radius: 0;
  line-height: 1.4;
  font-weight: 700;
  border: 3rpx solid #5b4215;
  box-shadow: 4rpx 0 0 rgba(138, 102, 34, 0.35), 0 4rpx 0 rgba(138, 102, 34, 0.35);
}

.btn-mini::after {
  border: none;
}

.section-title {
  font-weight: 700;
  margin-bottom: 18rpx;
  display: block;
  font-size: 28rpx;
  color: #8b7a58;
  letter-spacing: 1rpx;
}

.cat-row {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 3rpx dashed rgba(154, 122, 52, 0.3);
  font-size: 28rpx;
  color: #5c4a42;
}

.cat-row:last-child {
  border-bottom: none;
}

.cat-row text:first-child {
  flex: 1;
  font-weight: 500;
}

.link {
  color: #d48c00;
  margin-left: 24rpx;
  font-size: 26rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.link.danger {
  color: #e87868;
}

.tip {
  padding: 20rpx 36rpx;
  font-size: 24rpx;
}
