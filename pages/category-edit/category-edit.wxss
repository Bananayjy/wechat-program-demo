@import '../add/add.wxss';

.page {
  padding: 28rpx 0 48rpx;
  min-height: 100vh;
}

.add-bar {
  margin-bottom: 24rpx;
}

.seg.small {
  margin-bottom: 22rpx;
}

.add-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.add-row .input {
  flex: 1;
  background: rgba(255, 224, 130, 0.2);
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  border: 2rpx solid rgba(255, 193, 7, 0.18);
}

.btn-mini {
  font-size: 26rpx;
  padding: 18rpx 32rpx;
  background: linear-gradient(135deg, #ffe082 0%, #ffca28 100%);
  color: #fff;
  border-radius: 999rpx;
  line-height: 1.4;
  font-weight: 600;
  box-shadow: 0 6rpx 18rpx rgba(255, 179, 0, 0.28);
}

.btn-mini::after {
  border: none;
}

.section-title {
  font-weight: 700;
  margin-bottom: 18rpx;
  display: block;
  font-size: 28rpx;
  color: #8b7a58;
}

.cat-row {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 2rpx dashed rgba(255, 193, 7, 0.2);
  font-size: 28rpx;
  color: #5c4a42;
}

.cat-row:last-child {
  border-bottom: none;
}

.cat-row text:first-child {
  flex: 1;
  font-weight: 500;
}

.link {
  color: #d48c00;
  margin-left: 24rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.link.danger {
  color: #e87868;
}

.tip {
  padding: 20rpx 36rpx;
  font-size: 24rpx;
}
