.page {
  padding: 24rpx 0 48rpx;
  min-height: 100vh;
}

.add-bar {
  margin-bottom: 24rpx;
}

.seg.small {
  margin-bottom: 20rpx;
}

.add-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.add-row .input {
  flex: 1;
  background: #f3f4f6;
  border-radius: 12rpx;
  padding: 18rpx 22rpx;
  font-size: 28rpx;
}

.btn-mini {
  font-size: 26rpx;
  padding: 16rpx 28rpx;
  background: #1a7f5a;
  color: #fff;
  border-radius: 12rpx;
  line-height: 1.4;
}

.btn-mini::after {
  border: none;
}

.section-title {
  font-weight: 600;
  margin-bottom: 16rpx;
  display: block;
  font-size: 28rpx;
}

.cat-row {
  display: flex;
  align-items: center;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  font-size: 28rpx;
}

.cat-row:last-child {
  border-bottom: none;
}

.cat-row text:first-child {
  flex: 1;
}

.link {
  color: #1a7f5a;
  margin-left: 24rpx;
  font-size: 26rpx;
}

.link.danger {
  color: #c45c3e;
}

.tip {
  padding: 16rpx 32rpx;
  font-size: 24rpx;
}
