.page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  padding: 0 0 180rpx;
  box-sizing: border-box;
}

.summary-stage {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  justify-content: center;
  padding: 0 24rpx;
  min-height: 0;
}

.summary-swiper {
  width: 100%;
  height: 720rpx;
}

/* 包裹层固定高度，避免 swiper-item 内 height:100% 塌陷导致整页空白 */
.summary-item-wrap {
  height: 720rpx;
  box-sizing: border-box;
}

/* peek 时略收窄左右边距，与 next/previous-margin 搭配，避免两卡贴死 */
.card.summary-slide {
  margin: 0 12rpx;
}

.summary-slide {
  box-sizing: border-box;
  height: 100%;
  min-height: 0;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  padding: 12rpx 20rpx 16rpx;
  overflow-y: auto;
}

.hero-title {
  font-size: 32rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  margin-bottom: 24rpx;
  display: block;
  color: #8b7a58;
}

.hero-emoji {
  font-weight: normal;
}

.hero-row {
  display: flex;
  justify-content: space-between;
  gap: 32rpx;
  margin-bottom: 20rpx;
}

.hero-amount {
  font-size: 42rpx;
  font-weight: 700;
  margin-top: 10rpx;
  letter-spacing: 0.5rpx;
}

.hero-row + .rank-section {
  margin-top: 0;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(255, 193, 7, 0.18);
}

.rank-section + .rank-section {
  margin-top: 8rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(255, 193, 7, 0.18);
}

.rank-title {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  color: #a89878;
  margin-bottom: 12rpx;
  letter-spacing: 0.5rpx;
}

.rank-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 0;
  gap: 16rpx;
}

.rank-name {
  flex: 1;
  min-width: 0;
  font-size: 26rpx;
  color: #5c4a42;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.rank-amt {
  font-size: 26rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.rank-empty {
  display: block;
  font-size: 24rpx;
  color: #a89878;
  padding: 8rpx 0 4rpx;
}

/* 抬高以避免与 TabBar 重叠 */
.fab {
  position: fixed;
  left: 40rpx;
  right: 40rpx;
  bottom: calc(112rpx + constant(safe-area-inset-bottom));
  bottom: calc(112rpx + env(safe-area-inset-bottom));
  z-index: 10;
}
