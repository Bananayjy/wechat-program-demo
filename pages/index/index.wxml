<view class="page safe-bottom">
  <view class="summary-stage">
    <swiper
      class="book-swiper"
      current="{{bookSwiperIndex}}"
      duration="{{300}}"
      previous-margin="24rpx"
      next-margin="24rpx"
      bindchange="onBookSwiperChange"
    >
      <swiper-item wx:for="{{bookSlides}}" wx:key="bookId" wx:for-item="book">
        <view class="book-slide-inner">
          <scroll-view class="book-slide-scroll" scroll-y>
            <view class="card summary-slide summary-slide-stack">
              <text class="book-chip">{{book.bookName}}</text>
              <text class="hero-title">今日概览 <text class="hero-emoji">✨</text></text>
              <view class="hero-row">
                <view>
                  <text class="text-muted">收入</text>
                  <view class="amount-income hero-amount">¥{{book.todayIncome}}</view>
                </view>
                <view>
                  <text class="text-muted">支出</text>
                  <view class="amount-expense hero-amount">¥{{book.todayExpense}}</view>
                </view>
              </view>
              <view class="rank-section">
                <text class="rank-title">收入 TOP3</text>
                <block wx:if="{{book.todayRankIncome.length}}">
                  <view wx:for="{{book.todayRankIncome}}" wx:key="id" class="rank-row">
                    <text class="rank-name">{{item.name}}</text>
                    <text class="rank-amt amount-income">¥{{item.amount}}</text>
                  </view>
                </block>
                <block wx:else>
                  <text class="rank-empty">暂无记录</text>
                </block>
              </view>
              <view class="rank-section">
                <text class="rank-title">支出 TOP3</text>
                <block wx:if="{{book.todayRankExpense.length}}">
                  <view wx:for="{{book.todayRankExpense}}" wx:key="id" class="rank-row">
                    <text class="rank-name">{{item.name}}</text>
                    <text class="rank-amt amount-expense">¥{{item.amount}}</text>
                  </view>
                </block>
                <block wx:else>
                  <text class="rank-empty">暂无记录</text>
                </block>
              </view>
            </view>
          </scroll-view>
        </view>
      </swiper-item>
    </swiper>
  </view>

  <button class="btn-primary fab" bindtap="goAdd">记一笔 ✏️</button>

</view>
