{
  "pages": [
    "pages/index/index",
    "pages/list/list",
    "pages/stats/stats",
    "pages/mine/mine",
    "pages/login/login"
  ],
  "subpackages": [
    {
      "root": "pages/add",
      "pages": ["add"]
    },
    {
      "root": "pages/ledger-manage",
      "pages": ["ledger-manage"]
    },
    {
      "root": "pages/category-edit",
      "pages": ["category-edit"]
    },
    {
      "root": "pages/transaction-edit",
      "pages": ["transaction-edit"]
    }
  ],
  "preloadRule": {
    "pages/index/index": {
      "network": "all",
      "packages": ["pages/add"]
    },
    "pages/mine/mine": {
      "network": "all",
      "packages": ["pages/ledger-manage", "pages/category-edit"]
    },
    "pages/list/list": {
      "network": "all",
      "packages": ["pages/transaction-edit"]
    }
  },
  "window": {
    "navigationBarTitleText": "日常记账",
    "navigationBarBackgroundColor": "#E8A010",
    "navigationBarTextStyle": "white",
    "backgroundColor": "#FFFBEA"
  },
  "tabBar": {
    "color": "#B8A896",
    "selectedColor": "#E8A010",
    "backgroundColor": "#FFFEF8",
    "borderStyle": "white",
    "list": [
      {
        "pagePath": "pages/index/index",
        "text": "首页",
        "iconPath": "assets/tab-home.png",
        "selectedIconPath": "assets/tab-home-active.png"
      },
      {
        "pagePath": "pages/list/list",
        "text": "流水",
        "iconPath": "assets/tab-list.png",
        "selectedIconPath": "assets/tab-list-active.png"
      },
      {
        "pagePath": "pages/stats/stats",
        "text": "统计",
        "iconPath": "assets/tab-chart.png",
        "selectedIconPath": "assets/tab-chart-active.png"
      },
      {
        "pagePath": "pages/mine/mine",
        "text": "我的",
        "iconPath": "assets/tab-user.png",
        "selectedIconPath": "assets/tab-user-active.png"
      }
    ]
  },
  "style": "v2",
  "lazyCodeLoading": "requiredComponents",
  "sitemapLocation": "sitemap.json"
}
